# =====================================================================
# ScholarAI Environment Configurations Template
# =====================================================================

# FastAPI Application Environment
ENV=development
SECRET_KEY=scholarai_super_secret_key_change_me_in_production_1234567890

# Database Settings
# For SQLite (default development fallback):
DATABASE_URL=sqlite:///./scholarai.db

# For PostgreSQL (production standard):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scholarai

# Document Upload Directories
UPLOAD_DIR=./uploads

# AI Capabilities (Optionally fill this to enable premium Gemini QA/Summaries)
# If empty, the system automatically falls back to local Hugging Face CPU inference
GEMINI_API_KEY=
